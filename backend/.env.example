# Copy to .env locally. On Railway, set variables in the dashboard (do not commit .env).

PORT=5000
# Railway injects PORT automatically — leave unset on Railway unless debugging.

MONGODB_URI=mongodb://127.0.0.1:27017/simple_app
# Production: use Atlas SRV or Railway MongoDB plugin URI.

JWT_SECRET=change-me-in-production
# Production: use a long random secret (e.g. openssl rand -hex 64).

# Optional: public hostname for logs
# PUBLIC_HOST=your-app.up.railway.app