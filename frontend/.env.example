# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Full URL of the deployed backend API (must end with /api).
# Example (Railway):  EXPO_PUBLIC_API_URL=https://wmt12-production.up.railway.app/api
EXPO_PUBLIC_API_URL=https://wmt12-production.up.railway.app/api

# Override just the port when the URL is not set (default: 5000)
# EXPO_PUBLIC_API_PORT=5000
