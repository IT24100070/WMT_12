# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Full URL of the deployed backend API (must end with /api).
# Example (Railway):  EXPO_PUBLIC_API_URL=https://your-backend.up.railway.app/api
# Example (LAN dev):  EXPO_PUBLIC_API_URL=http://192.168.1.3:5000/api
EXPO_PUBLIC_API_URL=

# Override just the port when the URL is not set (default: 5000)
# EXPO_PUBLIC_API_PORT=5000
